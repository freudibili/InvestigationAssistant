# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Storage bucket used for uploaded interview PDFs
SUPABASE_STORAGE_BUCKET=case-documents

# Extraction provider: "openai" (default) or "anthropic"
EXTRACTION_PROVIDER=openai
# Cost/speed controls. Higher values mean fewer model calls, lower cost, and
# faster long documents, but dense pages may need fallback retries.
EXTRACTION_PAGES_PER_CHUNK=4
EXTRACTION_CONSOLIDATION_BATCH_SIZE=8

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5

# Anthropic (Claude) — used when EXTRACTION_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Output token ceiling per extraction call (Sonnet 4.6 max is 64000)
ANTHROPIC_MAX_TOKENS=32000
# Enable only when quality needs it; thinking can increase latency and cost.
ANTHROPIC_THINKING_ENABLED=false
